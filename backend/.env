# HubSpot Private App access token (required)
# Create at: HubSpot Account > Settings > Integrations > Private Apps
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# HubSpot App client secret (optional, for request signature validation)
# Find in: HubSpot Developer Account > Your App > Auth tab
# If not set, signature validation is skipped (not recommended for production)
HUBSPOT_CLIENT_SECRET=
